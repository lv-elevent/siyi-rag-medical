# 环境配置
# development: 显示详细调试日志（包括 PDF 清洗效果、分块示例等）
# production: 只显示关键信息日志
ENVIRONMENT=development

OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
CHROMA_COLLECTION_NAME=rag_docs

# 你的本地 MySQL 5.7 真实配置
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/medical_rag?charset=utf8mb4

# JWT 密钥 (随便写一个复杂的字符串即可)
SECRET_KEY=lgq_lbw_nb_110_2005